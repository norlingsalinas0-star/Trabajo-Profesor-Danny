const titulo = document.getElementById("titulo");
const descripcion = document.getElementById("descripcion");
const btnAgregar = document.getElementById("btnAgregar");
const listaTareas = document.getElementById("listaTareas");

btnAgregar.addEventListener("click", agregarTarea);

function agregarTarea(){

    const tituloValor = titulo.value;
    const descripcionValor = descripcion.value;

    const tarea = document.createElement("div");

    tarea.classList.add("tarea");

    tarea.innerHTML = `
    
        <h3>${tituloValor}</h3>

        <p>${descripcionValor}</p>

        <button class="eliminar">
            Eliminar
        </button>
    `;

    const btnEliminar = tarea.querySelector(".eliminar");

    btnEliminar.addEventListener("click", () => {
        tarea.remove();
    });

    listaTareas.appendChild(tarea);

    titulo.value = "";
    descripcion.value = "";
}

const titulo = document.getElementById("titulo");
const descripcion = document.getElementById("descripcion");
const btnAgregar = document.getElementById("btnAgregar");
const listaTareas = document.getElementById("listaTareas");

btnAgregar.addEventListener("click", agregarTarea);

let tareas = [];

function agregarTarea(){

    const tituloValor = titulo.value.trim();
    const descripcionValor = descripcion.value.trim();

    // VALIDACIÓN 1

    if(tituloValor === ""){
        alert("El título no puede estar vacío");
        return;
    }

    // VALIDACIÓN 2

    if(tituloValor.length < 3){
        alert("El título debe tener mínimo 3 caracteres");
        return;
    }

    // VALIDACIÓN 3

    if(descripcionValor.length > 100){
        alert("La descripción no puede superar 100 caracteres");
        return;
    }

    // VALIDACIÓN 4

    const existe = tareas.some(
        tarea => tarea.titulo.toLowerCase() === tituloValor.toLowerCase()
    );

    if(existe){
        alert("La tarea ya existe");
        return;
    }

    const tareaObjeto = {
        titulo: tituloValor,
        descripcion: descripcionValor
    };

    tareas.push(tareaObjeto);

    const tarea = document.createElement("div");

    tarea.classList.add("tarea");

    tarea.innerHTML = `
    
        <h3>${tituloValor}</h3>

        <p>${descripcionValor}</p>

        <button class="eliminar">
            Eliminar
        </button>
    `;

    const btnEliminar = tarea.querySelector(".eliminar");

    btnEliminar.addEventListener("click", () => {

        tareas = tareas.filter(
            t => t.titulo !== tituloValor
        );

        tarea.remove();
    });

    listaTareas.appendChild(tarea);

    titulo.value = "";
    descripcion.value = "";
}

